<?xml version="1.0"?>
<Container version="2">
  <Name>gluetun-MAC</Name>
  <Repository>gluetun-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/qdm12/gluetun</Support>
  <Project>https://github.com/qdm12/gluetun</Project>
  <Overview>Gluetun - VPN Gateway (MacGyver Stack)</Overview>
  <Category>Network:VPN</Category>
  <WebUI/>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/gluetun.svg</Icon>
  <ExtraParams>--restart=unless-stopped --cap-add=NET_ADMIN --device /dev/net/tun</ExtraParams>
  <Description>Gluetun VPN gateway for secure networking - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish/>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/gluetun-MAC</HostDir>
      <ContainerDir>/gluetun</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
    <Variable>
      <Value>surfshark</Value>
      <Name>VPN_SERVICE_PROVIDER</Name>
    </Variable>
  </Environment>
  <Config Name="Appdata" Target="/gluetun" Default="/mnt/user/appdata/gluetun-MAC" Mode="rw" Description="Gluetun config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/gluetun-MAC</Config>
</Container>