<?xml version="1.0"?>
<Container version="2">
  <Name>heimdall-MAC</Name>
  <Repository>heimdall-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://heimdall.site/</Support>
  <Project>https://github.com/linuxserver/Heimdall</Project>
  <Overview>Heimdall - Application Dashboard (MacGyver Stack)</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:80]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/heimdall.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Heimdall application dashboard - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>8082</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>8444</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/heimdall-MAC</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="HTTP Port" Target="80" Default="8082" Mode="tcp" Description="Heimdall HTTP Port" Type="Port" Display="always" Required="true" Mask="false">8082</Config>
  <Config Name="HTTPS Port" Target="443" Default="8444" Mode="tcp" Description="Heimdall HTTPS Port" Type="Port" Display="always" Required="true" Mask="false">8444</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/heimdall-MAC" Mode="rw" Description="Heimdall config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/heimdall-MAC</Config>
</Container>