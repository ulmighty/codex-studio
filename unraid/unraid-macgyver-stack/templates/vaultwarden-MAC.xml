<?xml version="1.0"?>
<Container version="2">
  <Name>vaultwarden-MAC</Name>
  <Repository>vaultwarden-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/dani-garcia/vaultwarden</Support>
  <Project>https://github.com/dani-garcia/vaultwarden</Project>
  <Overview>Vaultwarden - Password Manager (MacGyver Stack)</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/vaultwarden.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Vaultwarden password manager server - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>8087</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/vaultwarden-MAC</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="80" Default="8087" Mode="tcp" Description="Vaultwarden Web Interface" Type="Port" Display="always" Required="true" Mask="false">8087</Config>
  <Config Name="Appdata" Target="/data" Default="/mnt/user/appdata/vaultwarden-MAC" Mode="rw" Description="Vaultwarden data directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/vaultwarden-MAC</Config>
</Container>