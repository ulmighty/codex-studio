<?xml version="1.0"?>
<Container version="2">
  <Name>sabnzbd-MAC</Name>
  <Repository>sabnzbd-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://sabnzbd.org/</Support>
  <Project>https://github.com/sabnzbd/sabnzbd</Project>
  <Overview>SABnzbd - Usenet Downloader (MacGyver Stack)</Overview>
  <Category>Downloaders:</Category>
  <WebUI>http://[IP]:[PORT:8085]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/sabnzbd.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>SABnzbd usenet downloader - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>8085</HostPort>
        <ContainerPort>8080</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/sabnzbd-MAC</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/downloads</HostDir>
      <ContainerDir>/downloads</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/downloads/incomplete</HostDir>
      <ContainerDir>/incomplete-downloads</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="8080" Default="8080" Mode="tcp" Description="SABnzbd Web Interface" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/sabnzbd-MAC" Mode="rw" Description="SABnzbd config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/sabnzbd-MAC</Config>
</Container>