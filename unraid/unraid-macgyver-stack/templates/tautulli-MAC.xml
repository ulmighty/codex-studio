<?xml version="1.0"?>
<Container version="2">
  <Name>tautulli-MAC</Name>
  <Repository>tautulli-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://tautulli.com/</Support>
  <Project>https://github.com/Tautulli/Tautulli</Project>
  <Overview>Tautulli - Plex Statistics (MacGyver Stack)</Overview>
  <Category>MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:8181]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/tautulli.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Tautulli Plex monitoring - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>8181</HostPort>
        <ContainerPort>8181</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/tautulli-MAC</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="8181" Default="8181" Mode="tcp" Description="Tautulli Web Interface" Type="Port" Display="always" Required="true" Mask="false">8181</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/tautulli-MAC" Mode="rw" Description="Tautulli config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/tautulli-MAC</Config>
</Container>