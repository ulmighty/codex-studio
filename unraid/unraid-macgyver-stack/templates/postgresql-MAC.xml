<?xml version="1.0"?>
<Container version="2">
  <Name>postgresql-MAC</Name>
  <Repository>postgresql-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://www.postgresql.org/</Support>
  <Project>https://github.com/postgres/postgres</Project>
  <Overview>PostgreSQL - Database Server (MacGyver Stack)</Overview>
  <Category>Tools:</Category>
  <WebUI/>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/postgresql.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>PostgreSQL database server - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>5432</HostPort>
        <ContainerPort>5432</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/postgresql-MAC</HostDir>
      <ContainerDir>/var/lib/postgresql/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
    <Variable>
      <Value>macgyver</Value>
      <Name>POSTGRES_DB</Name>
    </Variable>
    <Variable>
      <Value>macgyver</Value>
      <Name>POSTGRES_USER</Name>
    </Variable>
    <Variable>
      <Value>macgyver123</Value>
      <Name>POSTGRES_PASSWORD</Name>
    </Variable>
  </Environment>
  <Config Name="Database Port" Target="5432" Default="5432" Mode="tcp" Description="PostgreSQL Database Port" Type="Port" Display="always" Required="true" Mask="false">5432</Config>
  <Config Name="Appdata" Target="/var/lib/postgresql/data" Default="/mnt/user/appdata/postgresql-MAC" Mode="rw" Description="PostgreSQL data directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/postgresql-MAC</Config>
</Container>