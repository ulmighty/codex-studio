<?xml version="1.0"?>
<Container version="2">
  <Name>prowlarr-MAC</Name>
  <Repository>prowlarr-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://prowlarr.com/</Support>
  <Project>https://github.com/Prowlarr/Prowlarr</Project>
  <Overview>Prowlarr - Indexer Manager (MacGyver Stack)</Overview>
  <Category>MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:9696]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/prowlarr.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Prowlarr indexer manager for *arr suite - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>9696</HostPort>
        <ContainerPort>9696</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/prowlarr-MAC</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="9696" Default="9696" Mode="tcp" Description="Prowlarr WebUI" Type="Port" Display="always" Required="true" Mask="false">9696</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/prowlarr-MAC" Mode="rw" Description="Prowlarr configuration" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/prowlarr-MAC</Config>
</Container>