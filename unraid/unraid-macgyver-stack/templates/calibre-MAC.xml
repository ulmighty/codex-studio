<?xml version="1.0"?>
<Container version="2">
  <Name>calibre-MAC</Name>
  <Repository>calibre-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://calibre-ebook.com/</Support>
  <Project>https://github.com/kovidgoyal/calibre</Project>
  <Overview>Calibre - Ebook Management (MacGyver Stack)</Overview>
  <Category>MediaApp:Books</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/calibre.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Calibre ebook management - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>8083</HostPort>
        <ContainerPort>8080</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>8181</HostPort>
        <ContainerPort>8181</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/calibre-MAC</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media/books</HostDir>
      <ContainerDir>/books</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="8080" Default="8083" Mode="tcp" Description="Calibre Web Interface" Type="Port" Display="always" Required="true" Mask="false">8083</Config>
  <Config Name="Server Port" Target="8181" Default="8181" Mode="tcp" Description="Calibre Server Port" Type="Port" Display="always" Required="true" Mask="false">8181</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/calibre-MAC" Mode="rw" Description="Calibre config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/calibre-MAC</Config>
</Container>