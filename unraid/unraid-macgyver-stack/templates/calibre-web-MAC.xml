<?xml version="1.0"?>
<Container version="2">
  <Name>calibre-web-MAC</Name>
  <Repository>calibre-web-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/janeczku/calibre-web</Support>
  <Project>https://github.com/janeczku/calibre-web</Project>
  <Overview>Calibre-Web - Web Interface for Calibre (MacGyver Stack)</Overview>
  <Category>MediaApp:Books</Category>
  <WebUI>http://[IP]:[PORT:8083]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/calibre-web.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Calibre-Web interface - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>8084</HostPort>
        <ContainerPort>8083</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/calibre-web-MAC</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media/books</HostDir>
      <ContainerDir>/books</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="8083" Default="8084" Mode="tcp" Description="Calibre-Web Interface" Type="Port" Display="always" Required="true" Mask="false">8084</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/calibre-web-MAC" Mode="rw" Description="Calibre-Web config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/calibre-web-MAC</Config>
</Container>