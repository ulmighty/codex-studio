<?xml version="1.0"?>
<Container version="2">
  <Name>traefik-MAC</Name>
  <Repository>traefik-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://traefik.io/</Support>
  <Project>https://github.com/traefik/traefik</Project>
  <Overview>Traefik - Reverse Proxy &amp; Load Balancer (MacGyver Stack)</Overview>
  <Category>Network:Proxy</Category>
  <WebUI>http://[IP]:[PORT:8079]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/traefik.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Traefik reverse proxy with SSL termination - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>8079</HostPort>
        <ContainerPort>8080</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/traefik-MAC</HostDir>
      <ContainerDir>/etc/traefik</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/var/run/docker.sock</HostDir>
      <ContainerDir>/var/run/docker.sock</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="HTTP Port" Target="80" Default="80" Mode="tcp" Description="HTTP Port" Type="Port" Display="always" Required="true" Mask="false">80</Config>
  <Config Name="HTTPS Port" Target="443" Default="443" Mode="tcp" Description="HTTPS Port" Type="Port" Display="always" Required="true" Mask="false">443</Config>
  <Config Name="Dashboard Port" Target="8080" Default="8079" Mode="tcp" Description="Traefik Dashboard" Type="Port" Display="always" Required="true" Mask="false">8079</Config>
  <Config Name="Appdata" Target="/etc/traefik" Default="/mnt/user/appdata/traefik-MAC" Mode="rw" Description="Traefik configuration" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/traefik-MAC</Config>
</Container>