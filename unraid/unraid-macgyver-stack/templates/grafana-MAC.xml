<?xml version="1.0"?>
<Container version="2">
  <Name>grafana-MAC</Name>
  <Repository>grafana-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://grafana.com/</Support>
  <Project>https://github.com/grafana/grafana</Project>
  <Overview>Grafana - Analytics &amp; Monitoring (MacGyver Stack)</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:3001]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/grafana.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Grafana analytics and monitoring dashboards - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>3001</HostPort>
        <ContainerPort>3000</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/grafana-MAC</HostDir>
      <ContainerDir>/var/lib/grafana</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
    <Variable>
      <Value>admin</Value>
      <Name>GF_SECURITY_ADMIN_USER</Name>
    </Variable>
    <Variable>
      <Value>admin</Value>
      <Name>GF_SECURITY_ADMIN_PASSWORD</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="3000" Default="3000" Mode="tcp" Description="Grafana WebUI" Type="Port" Display="always" Required="true" Mask="false">3000</Config>
  <Config Name="Appdata" Target="/var/lib/grafana" Default="/mnt/user/appdata/grafana-MAC" Mode="rw" Description="Grafana data directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/grafana-MAC</Config>
</Container>