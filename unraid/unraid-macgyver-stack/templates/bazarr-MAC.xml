<?xml version="1.0"?>
<Container version="2">
  <Name>bazarr-MAC</Name>
  <Repository>bazarr-mac:latest</Repository>
  <Registry/>
  <Network>macgyver-network-MAC</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://www.bazarr.media/</Support>
  <Project>https://github.com/morpheus65535/bazarr</Project>
  <Overview>Bazarr - Subtitle Management (MacGyver Stack)</Overview>
  <Category>MediaApp:Video</Category>
  <WebUI>http://[IP]:[PORT:6767]</WebUI>
  <Icon>https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/bazarr.svg</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Bazarr subtitle management - custom built for MacGyver Stack</Description>
  <Networking>
    <Mode>macgyver-network-MAC</Mode>
    <Publish>
      <Port>
        <HostPort>6767</HostPort>
        <ContainerPort>6767</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/bazarr-MAC</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media/movies</HostDir>
      <ContainerDir>/movies</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media/tv</HostDir>
      <ContainerDir>/tv</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
    </Variable>
    <Variable>
      <Value>America/Chicago</Value>
      <Name>TZ</Name>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="6767" Default="6767" Mode="tcp" Description="Bazarr Web Interface" Type="Port" Display="always" Required="true" Mask="false">6767</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/bazarr-MAC" Mode="rw" Description="Bazarr config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/bazarr-MAC</Config>
</Container>