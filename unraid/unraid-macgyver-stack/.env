# ============================================================================
# UNRAID MACGYVER STACK - VAULT BOOTSTRAP CONFIGURATION
# ============================================================================
# Place this file at: /mnt/user/docker_builds/.env
# This contains ONLY the essential secrets needed to bootstrap Vault
# Once Vault is running, it will manage all other application secrets
# ============================================================================

# ----------------------------------------------------------------------------
# CORE PROJECT SETTINGS
# ----------------------------------------------------------------------------
PROJECT_NAME=unraid-macgyver-stack
BUILD_VERSION=1.0.0
DOMAIN=ulmighty.local
TIMEZONE=America/New_York

# ----------------------------------------------------------------------------
# UNRAID SYSTEM CONFIGURATION
# ----------------------------------------------------------------------------
PUID=99
PGID=100
UMASK=000

# Unraid Paths
BUILD_PATH=/mnt/user/docker_builds/unraid-macgyver-stack
APPDATA_PATH=/mnt/user/appdata
DATA_PATH=/mnt/user/data
SCRIPTS_PATH=/mnt/user/scripts

# ----------------------------------------------------------------------------
# NETWORK & SECURITY
# ----------------------------------------------------------------------------
NETWORK_NAME=macgyver-network-MAC
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8079

# Base port for auto-assignment (will increment from here)
PORT_BASE=8000

# ----------------------------------------------------------------------------
# VAULT BOOTSTRAP CREDENTIALS
# ----------------------------------------------------------------------------
# CRITICAL: These are used ONLY to initialize Vault
# After Vault setup, change these and store in Vault itself

# Initial Vault root token (change after setup)
VAULT_ROOT_TOKEN=myroot

# Vault unseal keys (generated during init - update after first run)
VAULT_UNSEAL_KEY_1=VAULT_UNSEAL_KEY_1_PLACEHOLDER
VAULT_UNSEAL_KEY_2=VAULT_UNSEAL_KEY_2_PLACEHOLDER  
VAULT_UNSEAL_KEY_3=VAULT_UNSEAL_KEY_3_PLACEHOLDER

# Vault dev mode (set to 'false' for production)
VAULT_DEV_MODE=false
VAULT_DEV_ROOT_TOKEN_ID=${VAULT_ROOT_TOKEN}

# ----------------------------------------------------------------------------
# NORDVPN CREDENTIALS  
# ----------------------------------------------------------------------------
# Required for Gluetun VPN container (7 indexer apps)
NORDVPN_USERNAME=cjkiser@comcast.net
NORDVPN_PASSWORD='ocPJT%m0yO%n#i7hlcT$o3Elc%O'

# NordVPN server optimized for P2P and indexer searches
NORDVPN_SERVER=us9570.nordvpn.com
NORDVPN_COUNTRY="United States"

# Additional NordVPN optimization settings
NORDVPN_PROTOCOL=openvpn
NORDVPN_OPENVPN_PROTOCOL=udp
NORDVPN_CATEGORIES=P2P

# Gluetun health check and failover
VPN_HEALTH_CHECK_ENABLED=true
VPN_FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/16,172.16.0.0/12,10.0.0.0/8

# ----------------------------------------------------------------------------
# TLS/SSL CONFIGURATION
# ----------------------------------------------------------------------------
# mkcert will generate these automatically
TLS_CERT_PATH=/certs
TLS_CA_CERT=rootCA.pem
TLS_WILDCARD_CERT=_wildcard.ulmighty.local.pem
TLS_WILDCARD_KEY=_wildcard.ulmighty.local-key.pem

# ----------------------------------------------------------------------------
# DATABASE BOOTSTRAP
# ----------------------------------------------------------------------------
# PostgreSQL master credentials (will be moved to Vault after init)
POSTGRES_DB=macgyver_master
POSTGRES_USER=macgyver_admin
POSTGRES_PASSWORD='!3MbXS3#cya4CD&X'

# ----------------------------------------------------------------------------
# TRAEFIK BOOTSTRAP
# ----------------------------------------------------------------------------
# Traefik dashboard credentials (will be moved to Vault after init)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD='mfbaO$%tC12IbbbU'

# Optional: Cloudflare API token for external DNS challenges
# Leave empty if using only internal certificates
CLOUDFLARE_API_TOKEN=

# ----------------------------------------------------------------------------
# NOTIFICATION SERVICES (OPTIONAL)
# ----------------------------------------------------------------------------
# These will be moved to Vault after bootstrap

# Notifiarr API key (leave empty to skip notifications during setup)
NOTIFIARR_API_KEY=

# Discord webhook for setup notifications (optional)
DISCORD_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# PLEX CONFIGURATION
# ----------------------------------------------------------------------------
# Plex claim token - get from https://plex.tv/claim (valid for 4 minutes)
# Leave empty and set manually after deployment
PLEX_CLAIM=

# Plex Pass username (for hardware transcoding)
PLEX_USERNAME=your_plex_username
PLEX_PASSWORD=your_plex_password

# ----------------------------------------------------------------------------
# HARDWARE CONFIGURATION
# ----------------------------------------------------------------------------
# GPU support for Plex, Frigate, Unmanic
GPU_SUPPORT=true
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all

# ----------------------------------------------------------------------------
# DEVELOPMENT/DEBUG SETTINGS
# ----------------------------------------------------------------------------
# Set to 'true' for verbose logging during setup
DEBUG_MODE=false
VERBOSE_LOGGING=false

# Skip certain setup steps (for testing)
SKIP_CERT_GENERATION=false
SKIP_VAULT_INIT=false
SKIP_NETWORK_CREATION=false

# ============================================================================
# SECURITY NOTES:
# ============================================================================
# 1. Change ALL placeholder passwords before first run
# 2. After Vault is running, migrate all secrets TO Vault
# 3. Update this file to remove secrets and reference Vault paths
# 4. Backup Vault unseal keys securely (separate from this file)
# 5. Consider encrypting this file with gpg for additional security
# ============================================================================
